# HNAS local environment template
# Copy this file to `.env` and fill values as needed.

# -----------------------------------------------------------------------------
# AI provider configuration (Functions /api/ai/ask)
# -----------------------------------------------------------------------------
# Use OpenAI ChatGPT backend.
AI_MODEL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions

# Optional generic external model fallback (non-OpenAI endpoint)
# EXTERNAL_MODEL_PROVIDER=generic
# EXTERNAL_MODEL_ENDPOINT=
# EXTERNAL_MODEL_API_KEY=
# EXTERNAL_MODEL_NAME=external-model

# -----------------------------------------------------------------------------
# Flutter runtime values (used with --dart-define)
# -----------------------------------------------------------------------------
HNAS_API_BASE_URL=http://127.0.0.1:5001/demo-hnas/us-central1/api
HNAS_FIREBASE_PROJECT_ID=demo-hnas
HNAS_USE_FIREBASE_EMULATORS=true
HNAS_EMULATOR_HOST=127.0.0.1
HNAS_FIRESTORE_EMULATOR_PORT=8080
HNAS_AUTH_EMULATOR_PORT=9099

# Optional web Firebase bootstrap values (for local fallback config in main.dart)
HNAS_FIREBASE_API_KEY=demo-api-key
HNAS_FIREBASE_APP_ID=
HNAS_FIREBASE_MESSAGING_SENDER_ID=
