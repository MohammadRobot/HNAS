rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function currentUserExists() {
      return isAuthenticated() && exists(userPath(request.auth.uid));
    }

    function currentUser() {
      return get(userPath(request.auth.uid)).data;
    }

    function hasRole(roles) {
      return currentUserExists() &&
        currentUser().role is string &&
        currentUser().role in roles;
    }

    function canReadAiQaLog(logData) {
      return isAuthenticated() &&
        (
          hasRole(['supervisor', 'admin']) ||
          (
            hasRole(['nurse']) &&
            logData.actorUid is string &&
            logData.actorUid == request.auth.uid
          )
        );
    }

    match /users/{uid} {
      allow read: if isAuthenticated() &&
        (
          request.auth.uid == uid ||
          hasRole(['admin'])
        );
      allow write: if false;
    }

    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /aiQaLogs/{logId} {
        allow read: if canReadAiQaLog(resource.data);
        allow write: if false;
      }

      match /{subcollection}/{docId=**} {
        allow read: if subcollection != 'aiQaLogs' && isAuthenticated();
        allow write: if false;
      }
    }

    match /procedureTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if hasRole(['admin', 'supervisor']);
    }

    match /aiQaLogs/{logId} {
      allow read: if canReadAiQaLog(resource.data);
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
