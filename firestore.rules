rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function currentUserExists() {
      return isAuthenticated() && exists(userPath(request.auth.uid));
    }

    function currentUser() {
      return get(userPath(request.auth.uid)).data;
    }

    function hasRole(roles) {
      return currentUserExists() &&
        currentUser().role is string &&
        currentUser().role in roles;
    }

    function patientPath(patientId) {
      return /databases/$(database)/documents/patients/$(patientId);
    }

    function canAccessPatientData(patientData) {
      return isAuthenticated() &&
        (
          (
            hasRole(['nurse']) &&
            patientData.assignedNurseIds is list &&
            request.auth.uid in patientData.assignedNurseIds
          ) ||
          (
            hasRole(['admin', 'supervisor']) &&
            currentUser().agencyId is string &&
            patientData.agencyId is string &&
            patientData.agencyId == currentUser().agencyId
          )
        );
    }

    function canAccessPatientById(patientId) {
      return exists(patientPath(patientId)) &&
        canAccessPatientData(get(patientPath(patientId)).data);
    }

    function canReadAiQaLog(logData) {
      return isAuthenticated() &&
        (
          hasRole(['supervisor', 'admin']) ||
          (
            hasRole(['nurse']) &&
            logData.actorUid is string &&
            logData.actorUid == request.auth.uid
          )
        );
    }

    function canReadTopLevelAiQaLog(logData) {
      return canReadAiQaLog(logData) &&
        logData.patientId is string &&
        canAccessPatientById(logData.patientId);
    }

    match /users/{uid} {
      allow read: if isAuthenticated() &&
        (
          request.auth.uid == uid ||
          hasRole(['admin'])
        );
      allow write: if false;
    }

    match /patients/{patientId} {
      // Use resource.data for patient document reads so list queries (dashboard)
      // can be authorized deterministically by Firestore Rules.
      allow read: if canAccessPatientData(resource.data);
      allow write: if false;

      match /aiQaLogs/{logId} {
        allow read: if canAccessPatientById(patientId) && canReadAiQaLog(resource.data);
        allow write: if false;
      }

      match /{subcollection}/{docId=**} {
        allow read: if subcollection != 'aiQaLogs' && canAccessPatientById(patientId);
        allow write: if false;
      }
    }

    match /procedureTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if hasRole(['admin', 'supervisor']);
    }

    match /aiQaLogs/{logId} {
      allow read: if canReadTopLevelAiQaLog(resource.data);
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
